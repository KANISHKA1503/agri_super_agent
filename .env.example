# ============================================================
# AgriVoice Super-Agent — Environment Variables
# ============================================================
# Copy this file as `.env` and fill in your actual API keys.
# Run: copy .env.example .env
# ============================================================

# --- SARVAM AI (Required — powers ASR, TTS, and LLM) ---
# Sign up at: https://www.sarvam.ai/
# Go to Dashboard → API Keys → Create New Key
SARVAM_API_KEY=your_sarvam_api_key_here

# --- OPENWEATHERMAP (Required for weather queries) ---
# Sign up at: https://openweathermap.org/api
# Free tier gives 1000 calls/day
WEATHER_API_KEY=your_openweathermap_api_key_here

# --- GOVERNMENT DATA API (Optional — for live mandi prices) ---
# Sign up at: https://data.gov.in/
# Used for Tier 2 price lookup; system falls back to MSP database if absent
GOVT_DATA_API_KEY=your_data_gov_api_key_here

# --- EXOTEL (Required only for phone call integration) ---
# Sign up at: https://exotel.com/
# Not needed if you're testing router/RAG only via test_full.py
EXOTEL_ACCOUNT_SID=your_exotel_account_sid_here
EXOTEL_API_KEY=your_exotel_api_key_here
EXOTEL_API_TOKEN=your_exotel_api_token_here
